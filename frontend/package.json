    "@radix-ui/react-tooltip": "^1.1",
    "@tanstack/react-query": "^5.70",
    "@tanstack/react-router": "^1.100",
    "d3": "^7.9",
    "openapi-fetch": "^0.13",
    "react": "^19.1",
    "react-dom": "^19.1",
    "zustand": "^5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0",
    "@tailwindcss/vite": "^4.1",
